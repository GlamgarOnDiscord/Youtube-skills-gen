# ─── Required ───────────────────────────────────────────────────────────────────
# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# YouTube Data API v3 key (required for channels & playlists)
# https://console.cloud.google.com/apis/api/youtube.googleapis.com
YOUTUBE_API_KEY=

# ─── Optional – LLM ──────────────────────────────────────────────────────────────
# Model used for thematic analysis (fast, large context)
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview

# Model used for skill generation (best quality)
GEMINI_GENERATION_MODEL=gemini-3.1-pro-preview

# Temperature for generation (0.0 – 1.0)
GEMINI_TEMPERATURE=0.3

# Max output tokens per skill
GEMINI_MAX_OUTPUT_TOKENS=8192

# ─── Optional – Pipeline ─────────────────────────────────────────────────────────
# Maximum number of videos to process per run (0 = unlimited)
MAX_VIDEOS=0

# Maximum number of skills to generate per run
MAX_SKILLS=5

# Whether to skip videos without transcripts (true | false)
SKIP_NO_TRANSCRIPT=true

# Preferred transcript language (e.g. en, fr, de)
TRANSCRIPT_LANG=en

# ─── Optional – Storage ──────────────────────────────────────────────────────────
# Directory for cached transcripts/metadata
CACHE_DIR=.ysgen-cache

# Cache TTL in hours (0 = never expire)
CACHE_TTL_HOURS=168

# Default output directory for generated skills
OUTPUT_DIR=./output

# ─── Optional – Behaviour ────────────────────────────────────────────────────────
# Log level: silent | error | warn | info | debug
LOG_LEVEL=info

# Disable colored output
NO_COLOR=false
