{
  "name": "youtube-skills-gen",
  "version": "0.1.0",
  "description": "Transform YouTube content into Claude Code Skills using Gemini AI",
  "type": "module",
  "bin": {
    "ysgen": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "start": "bun run src/cli/index.ts",
    "generate": "bun run src/cli/index.ts generate",
    "fetch": "bun run src/cli/index.ts fetch",
    "inspect": "bun run src/cli/index.ts inspect",
    "build": "bun build src/cli/index.ts --outdir dist --target node --minify --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@google/generative-ai": "^0.21.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4"
  }
}
